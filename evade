-- ========== HÀM TẠO UI CON ==========
local function createSubGUI(titleText, icon)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 0, 45)
    container.BackgroundColor3 = Color3.fromRGB(0, 80, 120)
    container.BackgroundTransparency = 0.3
    container.BorderSizePixel = 0
    container.Parent = contentFrame
    
    local containerCorner = Instance.new("UICorner")
    containerCorner.CornerRadius = UDim.new(0, 8)
    containerCorner.Parent = container
    
    -- Tiêu đề con
    local subTitle = Instance.new("TextLabel")
    subTitle.Size = UDim2.new(1, -50, 0, 25)
    subTitle.Position = UDim2.new(0, 8, 0, 0)
    subTitle.BackgroundTransparency = 1
    subTitle.Text = icon .. " " .. titleText
    subTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    subTitle.Font = Enum.Font.GothamSemibold
    subTitle.TextSize = 11
    subTitle.TextXAlignment = Enum.TextXAlignment.Left
    subTitle.Parent = container
    
    -- Nút bật/tắt
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 60, 0, 24)
    btn.Position = UDim2.new(1, -68, 0.5, -12)
    btn.BackgroundColor3 = Color3.fromRGB(0, 60, 90)
    btn.Text = "OFF"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 11
    btn.BorderSizePixel = 0
    btn.Parent = container
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    -- Hover effect
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(0, 80, 110)
    end)
    btn.MouseLeave:Connect(function()
        if btn.Text == "ON" then
            btn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
        else
            btn.BackgroundColor3 = Color3.fromRGB(0, 60, 90)
        end
    end)
    
    return container, btn
end

-- ========== AUTO JUMP (Bấm Space liên tục) ==========
local jumpContainer, jumpBtn = createSubGUI("AUTO JUMP", "🦘")
local jumpActive = false
local jumpConnection = nil
local jumpDelay = 0.15 -- delay giữa các lần nhảy (giây)

local function startAutoJump()
    if jumpActive then return end
    jumpActive = true
    
    jumpConnection = runService.Heartbeat:Connect(function()
        if jumpActive and player.Character and player.Character:FindFirstChild("Humanoid") then
            -- Mô phỏng bấm phím Space
            local jumpEvent = {
                KeyCode = Enum.KeyCode.Space,
                UserInputType = Enum.UserInputType.Keyboard
            }
            userInput:SetKeyDown(Enum.KeyCode.Space)
            task.wait(0.05)
            userInput:SetKeyUp(Enum.KeyCode.Space)
            task.wait(jumpDelay)
        end
    end)
    
    jumpBtn.Text = "ON"
    jumpBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
    print("✅ AUTO JUMP ĐÃ BẬT")
end

local function stopAutoJump()
    if not jumpActive then return end
    jumpActive = false
    
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end
    
    -- Đảm bảo thả phím Space
    userInput:SetKeyUp(Enum.KeyCode.Space)
    
    jumpBtn.Text = "OFF"
    jumpBtn.BackgroundColor3 = Color3.fromRGB(0, 60, 90)
    print("❌ AUTO JUMP ĐÃ TẮT")
end

jumpBtn.MouseButton1Click:Connect(function()
    if jumpActive then
        stopAutoJump()
    else
        startAutoJump()
    end
end)

-- ========== AUTO CTRL (Giữ Ctrl liên tục) ==========
local ctrlContainer, ctrlBtn = createSubGUI("AUTO CTRL", "🎮")
local ctrlActive = false
local ctrlConnection = nil

local function startAutoCtrl()
    if ctrlActive then return end
    ctrlActive = true
    
    -- Giữ phím LeftControl
    userInput:SetKeyDown(Enum.KeyCode.LeftControl)
    
    -- Kiểm tra liên tục để đảm bảo vẫn giữ
    ctrlConnection = runService.Heartbeat:Connect(function()
        if ctrlActive then
            if not userInput:IsKeyDown(Enum.KeyCode.LeftControl) then
                userInput:SetKeyDown(Enum.KeyCode.LeftControl)
            end
        end
    end)
    
    ctrlBtn.Text = "ON"
    ctrlBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
    print("✅ AUTO CTRL ĐÃ BẬT (Đang giữ Ctrl)")
end

local function stopAutoCtrl()
    if not ctrlActive then return end
    ctrlActive = false
    
    if ctrlConnection then
        ctrlConnection:Disconnect()
        ctrlConnection = nil
    end
    
    -- Thả phím LeftControl
    userInput:SetKeyUp(Enum.KeyCode.LeftControl)
    
    ctrlBtn.Text = "OFF"
    ctrlBtn.BackgroundColor3 = Color3.fromRGB(0, 60, 90)
    print("❌ AUTO CTRL ĐÃ TẮT")
end

ctrlBtn.MouseButton1Click:Connect(function()
    if ctrlActive then
        stopAutoCtrl()
    else
        startAutoCtrl()
    end
end)

-- ========== CẬP NHẬT CHIỀU CAO ==========
local function updateHeight()
    task.wait(0.05)
    local totalHeight = contentLayout.AbsoluteContentSize.Y
    contentFrame.Size = UDim2.new(1, -10, 0, totalHeight + 10)
end

contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateHeight)
task.wait(0.1)
updateHeight()

-- ========== THU GỌN/MỞ RỘNG ==========
local expanded = true

local function setExpanded(exp)
    expanded = exp
    if exp then
        -- Mở rộng
        local frameTween = tweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 200, 0, 140)
        })
        frameTween:Play()
        
        local contentTween = tweenService:Create(contentFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(1, -10, 0, 90)
        })
        contentTween:Play()
        
        toggleBtn.Text = "▼"
    else
        -- Thu gọn
        local frameTween = tweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 200, 0, 45)
        })
        frameTween:Play()
        
        local contentTween = tweenService:Create(contentFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(1, -10, 0, 0)
        })
        contentTween:Play()
        
        toggleBtn.Text = "▲"
    end
end

toggleBtn.MouseButton1Click:Connect(function()
    setExpanded(not expanded)
end)

-- ========== XỬ LÝ KHI THOÁT GAME ==========
-- Tự động tắt tất cả khi người chơi rời khỏi game (không cần, nhưng để an toàn)
player:GetPropertyChangedSignal("Character"):Connect(function()
    if not player.Character then
        -- Người chơi đã chết hoặc rời game, tắt tất cả
        if jumpActive then stopAutoJump() end
        if ctrlActive then stopAutoCtrl() end
    end
end)

-- ========== XỬ LÝ KHI RESPAWN ==========
player.CharacterAdded:Connect(function()
    -- Khi respawn, nếu auto jump đang bật thì vẫn giữ (không cần reset)
    -- Nhưng auto ctrl thì cần bật lại
    if ctrlActive then
        task.wait(0.5)
        userInput:SetKeyDown(Enum.KeyCode.LeftControl)
    end
end)

