local autoJumpActive = false
local autoCtrlActive = false
local jumpConnection = nil
local ctrlConnection = nil

-- ========== AUTO JUMP FUNCTION ==========
local function enableAutoJump()
    if autoJumpActive then return end
    autoJumpActive = true
    
    -- Mỗi frame sẽ nhảy (không cần giữ)
    jumpConnection = runService.Heartbeat:Connect(function()
        if autoJumpActive and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid:GetState() ~= Enum.HumanoidStateType.Jumping then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end)
    
    jumpButton.Text = "🟢 AUTO JUMP ON"
    jumpButton.BackgroundColor3 = Color3.fromRGB(0, 120, 80)
    print("✅ AUTO JUMP ĐÃ BẬT")
end

local function disableAutoJump()
    if not autoJumpActive then return end
    autoJumpActive = false
    
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end
    
    jumpButton.Text = "🔴 AUTO JUMP OFF"
    jumpButton.BackgroundColor3 = Color3.fromRGB(0, 80, 120)
    print("❌ AUTO JUMP ĐÃ TẮT")
end

jumpButton.MouseButton1Click:Connect(function()
    if autoJumpActive then
        disableAutoJump()
    else
        enableAutoJump()
    end
end)

jumpButton.MouseEnter:Connect(function()
    if autoJumpActive then
        jumpButton.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
    else
        jumpButton.BackgroundColor3 = Color3.fromRGB(0, 110, 150)
    end
end)

jumpButton.MouseLeave:Connect(function()
    if autoJumpActive then
        jumpButton.BackgroundColor3 = Color3.fromRGB(0, 120, 80)
    else
        jumpButton.BackgroundColor3 = Color3.fromRGB(0, 80, 120)
    end
end)

-- ========== AUTO CTRL FUNCTION (GIỮ PHÍM) ==========
local function enableAutoCtrl()
    if autoCtrlActive then return end
    autoCtrlActive = true
    
    -- Giả lập giữ phím Ctrl liên tục
    local ctrlKey = Enum.KeyCode.LeftControl
    
    -- Gửi sự kiện phím xuống
    local function sendCtrlDown()
        local keyDownEvent = {
            KeyCode = ctrlKey,
            UserInputType = Enum.UserInputType.Keyboard
        }
        -- Mô phỏng nhấn giữ Ctrl
        userInput.InputBegan:Fire(keyDownEvent)
    end
    
    -- Gửi mỗi frame để đảm bảo giữ liên tục
    ctrlConnection = runService.Heartbeat:Connect(function()
        if autoCtrlActive then
            sendCtrlDown()
        end
    end)
    
    -- Gửi ngay lập tức
    sendCtrlDown()
    
    ctrlButton.Text = "🟢 AUTO CTRL ON"
    ctrlButton.BackgroundColor3 = Color3.fromRGB(0, 120, 80)
    print("✅ AUTO CTRL ĐÃ BẬT - Đang giữ phím Ctrl")
end

local function disableAutoCtrl()
    if not autoCtrlActive then return end
    autoCtrlActive = false
    
    if ctrlConnection then
        ctrlConnection:Disconnect()
        ctrlConnection = nil
    end
    
    -- Thả phím Ctrl
    local ctrlKey = Enum.KeyCode.LeftControl
    local keyUpEvent = {
        KeyCode = ctrlKey,
        UserInputType = Enum.UserInputType.Keyboard
    }
    userInput.InputEnded:Fire(keyUpEvent)
    
    ctrlButton.Text = "🔴 AUTO CTRL OFF"
    ctrlButton.BackgroundColor3 = Color3.fromRGB(0, 80, 120)
    print("❌ AUTO CTRL ĐÃ TẮT - Đã thả phím Ctrl")
end

ctrlButton.MouseButton1Click:Connect(function()
    if autoCtrlActive then
        disableAutoCtrl()
    else
        enableAutoCtrl()
    end
end)

ctrlButton.MouseEnter:Connect(function()
    if autoCtrlActive then
        ctrlButton.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
    else
        ctrlButton.BackgroundColor3 = Color3.fromRGB(0, 110, 150)
    end
end)

ctrlButton.MouseLeave:Connect(function()
    if autoCtrlActive then
        ctrlButton.BackgroundColor3 = Color3.fromRGB(0, 120, 80)
    else
        ctrlButton.BackgroundColor3 = Color3.fromRGB(0, 80, 120)
    end
end)

-- ========== XỬ LÝ KHI NHÂN VẬT RESPAWN ==========
player.CharacterAdded:Connect(function(character)
    repeat task.wait() until character:FindFirstChild("Humanoid")
    
    -- Nếu Auto Jump đang bật, vẫn tiếp tục (tự động bật lại)
    if autoJumpActive then
        -- Tạm tắt rồi bật lại để refresh
        disableAutoJump()
        task.wait(0.1)
        enableAutoJump()
    end
    
    -- Auto Ctrl vẫn giữ nguyên trạng thái
    if autoCtrlActive then
        -- Refresh auto ctrl
        disableAutoCtrl()
        task.wait(0.1)
        enableAutoCtrl()
    end
end)

-- ========== THU GỌN/MỞ RỘNG CHO GUI CHÍNH ==========
local expanded = true

local function setExpanded(exp)
    expanded = exp
    local targetHeight = exp and 130 or 45
    local targetContainerSize = exp and 85 or 0
    
    local frameTween = tweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 200, 0, targetHeight)
    })
    frameTween:Play()
    
    local containerTween = tweenService:Create(container, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(1, -10, 0, targetContainerSize)
    })
    containerTween:Play()
    
    toggleBtn.Text = exp and "▲" or "▼"
end

